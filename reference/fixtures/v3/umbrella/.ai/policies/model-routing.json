{
  "schema_version": "1.0",
  "description": "Provider-neutral model-routing policy (ADR-0003). Task classes map to portable tiers; host_aliases bind tiers to concrete host model names per provider.",
  "tiers": ["frontier", "mid", "cheap"],
  "task_classes": {
    "requirements": "frontier",
    "architecture": "frontier",
    "initial-implementation": "frontier",
    "hard-verification": "frontier",
    "standard-implementation": "mid",
    "planning": "mid",
    "test-generation": "cheap",
    "first-pass-code-review": "cheap",
    "ci-monitoring": "cheap",
    "lookups": "cheap"
  },
  "host_aliases": {
    "claude": {
      "frontier": "opus",
      "mid": "sonnet",
      "cheap": "haiku"
    },
    "codex": {
      "frontier": "gpt-5-codex-high",
      "mid": "gpt-5-codex",
      "cheap": "gpt-5-codex-mini"
    }
  }
}
