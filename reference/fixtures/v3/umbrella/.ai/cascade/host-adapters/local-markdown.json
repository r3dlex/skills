{
  "schema_version": "1.0",
  "host": "local-markdown",
  "host_label": "Local Markdown",
  "hosted": false,
  "adapter_doc": "setup-skills/issue-tracker-local.md",
  "operations": [
    "discover_scope",
    "plan_parent_item",
    "plan_child_item",
    "dry_run",
    "confirm_first_run",
    "apply_confirmed_plan",
    "readback_links",
    "apply_idempotent_update",
    "audit_event",
    "reconcile"
  ],
  "safety": {
    "first_run_without_confirmation": "not-required-local-write",
    "confirmation_token_required": false,
    "confirmation_token": null,
    "credentials_stored": false,
    "host_policy_mutation": false
  },
  "dry_run": {
    "status": "planned",
    "would_create_parent": true,
    "would_create_children": 2
  },
  "apply": {
    "status": "created-or-linked",
    "parent_key": ".scratch/init-ai-repo/parent.md",
    "child_keys": [
      ".scratch/init-ai-repo/issues/01-service-auth.md"
    ]
  },
  "second_run": {
    "status": "updated-existing",
    "duplicates_created": 0,
    "idempotency_key": "init-ai-repo:umbrella-root:cascade"
  },
  "readback": {
    "status": "match",
    "parent_link_present": true,
    "child_links_present": true
  },
  "audit_path": ".ai/cascade/audit.jsonl"
}
