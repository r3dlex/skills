{
  "schema_version": "1.0",
  "cascade_id": "cascade:umbrella-root:init-ai-repo",
  "root_repo_id": "umbrella-root",
  "topology_type": "umbrella",
  "matrix_path": ".ai/matrix.json",
  "managed_repositories": [
    "services/auth",
    "services/billing"
  ],
  "configured_hosts": [
    "github",
    "ado",
    "gitlab",
    "jira",
    "local-markdown"
  ],
  "first_run_confirmation_required": true,
  "confirmation_token_pattern": "^ct-[0-9]{4}-[0-9]{2}-[0-9]{2}-[0-9]{3}$",
  "idempotency_key": "init-ai-repo:umbrella-root:cascade",
  "parent_item": {
    "stable_id": "issue:umbrella-root:init-ai-repo-parent",
    "title": "Initialize AI SDLC across repository set"
  },
  "child_items": [
    {
      "stable_id": "issue:umbrella-root:services-auth",
      "repo_path": "services/auth",
      "parent_stable_id": "issue:umbrella-root:init-ai-repo-parent"
    },
    {
      "stable_id": "issue:umbrella-root:services-billing",
      "repo_path": "services/billing",
      "parent_stable_id": "issue:umbrella-root:init-ai-repo-parent"
    }
  ],
  "dry_run_path": ".ai/cascade/cascade-plan.json",
  "audit_path": ".ai/cascade/audit.jsonl",
  "reconciliation_report": ".ai/cascade/reconciliation-report.md",
  "safety": {
    "no_first_run_apply_without_confirmation": true,
    "no_duplicate_child_items": true,
    "no_secret_material": true,
    "host_policy_mutations_out_of_scope": true
  }
}
