name: DPUA validation selector
on: [push, pull_request, workflow_dispatch]
permissions:
  actions: read
  contents: read
jobs:
  select:
    runs-on: @@HOSTED_IMAGE@@
    outputs:
      executor: ${{ steps.selector.outputs.executor }}
      runs_on: ${{ steps.selector.outputs.runs_on }}
    steps:
      - id: selector
        run: >-
          python3 tools/ci-engine/provider_selector.py resolve
          --provider github --profile .ai/execution/profiles/execution/default.json
          --task-class validation --preference @@RUNNER_PREFERENCE@@
  primary:
    needs: select
    runs-on: ${{ fromJSON(needs.select.outputs.runs_on) }}
    steps:
      - run: python3 tools/ci-engine/provider_selector.py execute --provider github --attempt 0 -- moon ci
  retry:
    needs: [select, primary]
    if: failure()
    runs-on: ${{ fromJSON(needs.select.outputs.runs_on) }}
    steps:
      - run: python3 tools/ci-engine/provider_selector.py retry-transient --provider github --max-retries 1 -- moon ci
